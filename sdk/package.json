{
  "name": "plaky115",
  "version": "0.1.0",
  "author": "Plaky115",
  "type": "module",
  "main": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "README.md",
    "esm",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "default": "./esm/index.js"
    },
    "./runtime/*.js": {
      "types": "./esm/runtime/*.d.ts",
      "import": "./esm/runtime/*.js",
      "default": "./esm/runtime/*.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node ../scripts/clean-package-builds.mjs sdk && tsgo",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src test --deny-warnings",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:types": "npm run build && tsd",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.60.0",
    "tsd": "^0.33.0",
    "typescript": "~5.8.3"
  },
  "description": "Hand-crafted TypeScript SDK for the Plaky public API. Unofficial.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apet97/plaky115"
  }
}
