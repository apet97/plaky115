{
  "name": "plaky115-toolkit-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "overlay:validate": "ruby scripts/apply-overlay.rb --source api-1.yaml --overlay overlays/plaky115-dx.overlay.yaml --check",
    "overlay:apply": "ruby scripts/apply-overlay.rb --source api-1.yaml --overlay overlays/plaky115-dx.overlay.yaml --out openapi/plaky115-dx.openapi.yaml",
    "metadata:generate": "ruby scripts/generate-operation-metadata.rb",
    "metadata:test": "ruby scripts/test-operation-metadata.rb",
    "lint:openapi": "ruby scripts/lint-openapi.rb api-1.yaml openapi/plaky115-dx.openapi.yaml",
    "openapi:test": "ruby scripts/test-overlay-application.rb && ruby scripts/test-openapi-lint.rb",
    "secret:scan": "bash -lc '! rg -n \"plk_[A-Za-z0-9]{16,}\" . -g \"!**/node_modules/**\" -g \"!**/.git/**\"'",
    "goreleaser:check": "cd cli && goreleaser check --config .goreleaser.yaml",
    "postgen": "node scripts/postgen-dx.mjs",
    "regenerate": "node scripts/regenerate.mjs",
    "verify": "npm run verify:offline",
    "verify:offline": "npm run overlay:validate && npm run lint:openapi && npm run openapi:test && npm run metadata:test && npm run generated:drift && npm run codegen:test && npm run postgen:drift && npm run docs:surface:test && npm run examples:check && npm run live:sweep:test && npm --prefix sdk run typecheck && npm --prefix sdk run test:types && npm --prefix sdk run lint && npm --prefix sdk test && npm --prefix mcp-server run lint && npm --prefix mcp-server test && (cd cli && go test ./... && go build -o /tmp/plaky115 ./cmd/plaky115 && /tmp/plaky115 --help >/dev/null && /tmp/plaky115 raw --help >/dev/null && PLAKY115_API_KEY=ci-stub /tmp/plaky115 doctor >/dev/null) && npm run parity:test && npm run status:surfaces:strict && npm run artifacts:audit && npm run pack:smoke && npm run packsnapshot:drift && npm run package:consumer-smoke && npm run secret:scan && npm run goreleaser:check",
    "live:sweep": "node scripts/live-workspace-sweep.mjs",
    "status:surfaces": "node scripts/status-surfaces.mjs",
    "status:surfaces:json": "node scripts/status-surfaces.mjs --json",
    "status:surfaces:strict": "node scripts/status-surfaces.mjs --strict",
    "test:surfaces": "node --test scripts/test-surface-audit.mjs",
    "docs:surface:test": "node --test scripts/test-docs-surface.mjs",
    "examples:check": "node scripts/check-examples.mjs",
    "live:sweep:test": "node --test scripts/test-live-sweep-source.mjs",
    "generated:drift": "node scripts/check-generated-drift.mjs",
    "postgen:drift": "node scripts/check-postgen-drift.mjs",
    "artifacts:audit": "node scripts/audit-package-artifacts.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "packsnapshot:write": "node scripts/pack-snapshot.mjs --write",
    "packsnapshot:drift": "node scripts/pack-snapshot.mjs --check",
    "package:consumer-smoke": "node scripts/package-consumer-smoke.mjs",
    "generate:types": "node scripts/generate-types.mjs",
    "generate:mcp": "node scripts/generate-mcp.mjs",
    "generate:cli": "node scripts/generate-cli.mjs",
    "generate:docs-index": "node scripts/generate-docs-index.mjs",
    "generate:all": "node scripts/generate-all.mjs",
    "codegen:test": "node --test scripts/test-codegen-determinism.mjs",
    "parity:test": "node --test scripts/test-cross-surface-parity.mjs"
  }
}
